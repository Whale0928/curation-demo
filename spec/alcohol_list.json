{
  "openapi": "3.0.3",
  "info": {
    "title": "위스키 목록 추천",
    "description": "추천 위스키를 카드 N개로 나열하는 큐레이션. 각 카드는 알코올 마스터에서 hydrate된 정보(국가·카테고리·캐스크·도수·태그·평점·찜수)와 큐레이터 코멘트로 구성된다.",
    "version": "1.0.0"
  },
  "x-curation": {
    "code": "ALCOHOL_LIST",
    "hydratorKey": "alcohol",
    "container": "array"
  },
  "paths": {},
  "components": {
    "schemas": {
      "AlcoholListItemRequest": {
        "type": "object",
        "description": "위스키 목록 추천 큐레이션의 한 카드(항목) 등록 요청",
        "x-form-style": "alcohol-list",
        "properties": {
          "alcoholId": {
            "type": "integer",
            "format": "int64",
            "description": "알코올 ID (참조키). 카드 본문에 마스터 정보가 자동 hydrate.",
            "example": 1,
            "x-field-style": "alcohol-card",
            "x-display-name": "위스키"
          },
          "comment": {
            "type": "string",
            "description": "마스터 정보 외 추가로 적고 싶은 한 줄",
            "example": "셰리 캐스크의 진한 단맛이 인상적",
            "x-field-style": "long-text",
            "x-display-name": "큐레이터 코멘트 · 선택"
          }
        },
        "required": ["alcoholId"]
      },
      "AlcoholListItemResponse": {
        "type": "object",
        "description": "위스키 목록 추천의 한 카드 조회 응답. alcohol 마스터 + 평점·찜 집계 hydrate.",
        "x-form-style": "alcohol-list",
        "x-graphql": {
          "query":   "alcohols",
          "argFrom": "$.alcoholId",
          "argName": "ids",
          "argType": "[ID!]!"
        },
        "properties": {
          "alcoholId":         { "type": "integer", "format": "int64", "description": "알코올 ID (참조키)", "example": 1, "x-field-style": "alcohol-card", "x-display-name": "위스키 ID", "x-graphql": true },
          "comment":           { "type": "string", "description": "큐레이터 코멘트", "example": "셰리 캐스크의 진한 단맛이 인상적", "x-field-style": "long-text", "x-display-name": "큐레이터 코멘트" },
          "korName":           { "type": "string", "description": "알코올 한글명", "example": "라이터스 티얼즈 레드 헤드", "x-field-style": "plain-text", "x-display-name": "이름 (한글)", "x-graphql": true },
          "engName":           { "type": "string", "description": "알코올 영문명", "example": "Writers' Tears Red Head", "x-field-style": "plain-text", "x-display-name": "이름 (영문)", "x-graphql": true },
          "imageUrl":          { "type": "string", "description": "대표 이미지 URL", "example": "https://img/...", "x-field-style": "image-url", "x-display-name": "이미지", "x-graphql": true },
          "regionName":        { "type": "string", "description": "지역(국가) 한글명", "example": "아일랜드", "x-field-style": "plain-text", "x-display-name": "국가", "x-graphql": true },
          "korCategory":       { "type": "string", "description": "카테고리 한글명", "example": "싱글 몰트", "x-field-style": "plain-text", "x-display-name": "카테고리", "x-graphql": true },
          "engCategory":       { "type": "string", "description": "카테고리 영문명", "example": "Single Malt", "x-field-style": "plain-text", "x-display-name": "카테고리 (영문)", "x-graphql": true },
          "cask":              { "type": "string", "description": "캐스크 정보", "example": "Oloroso Sherry Butts", "x-field-style": "plain-text", "x-display-name": "캐스크", "x-graphql": true },
          "abv":               { "type": "string", "description": "알코올 도수 (%)", "example": "46", "x-field-style": "plain-text", "x-display-name": "도수", "x-graphql": true },
          "volume":            { "type": "string", "description": "용량", "example": "700ml", "x-field-style": "plain-text", "x-display-name": "용량", "x-graphql": true },
          "rating":            { "type": "number", "format": "double", "description": "평균 별점 (소수점 2자리)", "example": 4.25, "x-field-style": "rating-display", "x-display-name": "평균 별점", "nullable": true, "x-graphql": true },
          "totalRatingsCount": { "type": "integer", "format": "int64", "description": "별점 참여자 수", "example": 4, "x-field-style": "count", "x-display-name": "별점 참여자 수", "x-graphql": true },
          "reviewCount":       { "type": "integer", "format": "int64", "description": "리뷰 수 (데모: ratings 와 동일 source)", "example": 4, "x-field-style": "count", "x-display-name": "리뷰 수", "x-graphql": true },
          "totalPickCount":    { "type": "integer", "format": "int64", "description": "좋아요(찜) 수", "example": 3, "x-field-style": "count", "x-display-name": "좋아요 수", "x-graphql": true },
          "tags": {
            "type": "array",
            "description": "테이스팅 태그 목록",
            "example": [{ "id": 58, "korName": "크리미", "engName": "creamy" }],
            "x-field-style": "tag-list",
            "x-display-name": "테이스팅 태그",
            "x-graphql": true,
            "items": {
              "type": "object",
              "description": "태그 단건",
              "example": { "id": 58, "korName": "크리미", "engName": "creamy" },
              "x-field-style": "tag-item",
              "properties": {
                "id":      { "type": "integer", "format": "int64", "description": "태그 ID", "example": 58, "x-field-style": "plain-number", "x-display-name": "태그 ID", "x-graphql": true },
                "korName": { "type": "string", "description": "태그 한글명", "example": "크리미", "x-field-style": "plain-text", "x-display-name": "태그명", "x-graphql": true },
                "engName": { "type": "string", "description": "태그 영문명", "example": "creamy", "x-field-style": "plain-text", "x-display-name": "태그명 (영문)", "x-graphql": true }
              },
              "required": ["id", "korName"]
            }
          }
        },
        "required": ["alcoholId", "korName"]
      }
    }
  }
}
