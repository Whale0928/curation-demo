          "items":       { "type": "array",  "items": { "type": "object" } },
          "alcohols":    { "type": "array",  "items": { "type": "object" } },
          "links":       { "type": "array",  "items": { "type": "object" } },
          "stats":       { "type": "object" }
        }
      }
    }
  }
