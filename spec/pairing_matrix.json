{
  "openapi": "3.0.3",
  "info": {
    "title": "페어링 (N:N 자유 연결)",
    "description": "위스키 배열 + 음식 배열 + 연결 N:N. 양방향 매트릭스 편집.",
    "version": "1.0.0"
  },
  "x-curation": {
    "code": "PAIRING_MATRIX",
    "hydratorKey": "alcohol",
    "container": "object"
  },
  "paths": {},
  "components": {
    "schemas": {
      "PairingMatrixCurationRequest": {
        "type": "object",
        "description": "페어링 매트릭스 큐레이션 통째 등록 요청 (위스키 + 음식 + 연결)",
        "properties": {
          "primaryAxis": {
            "type": "string",
            "enum": ["ALCOHOL_TO_ITEM", "ITEM_TO_ALCOHOL"],
            "x-display-name": "기준 축",
            "description": "기준 축 — UI 노출 방향만 결정. 데이터 의미는 양방향 동일."
          },
          "items": {
            "type": "array",
            "minItems": 1,
            "x-display-name": "음식 목록",
            "description": "음식(아이템) 목록. 각 항목은 클라이언트가 부여한 itemId 로 식별.",
            "items": {
              "type": "object",
              "properties": {
                "itemId":   { "type": "string", "x-display-name": "음식 임시 ID", "description": "음식 임시 ID (클라이언트 부여, links 와 매칭에 사용)" },
                "name":     { "type": "string", "x-display-name": "음식 이름", "description": "음식 이름" },
                "imageUrl": { "type": "string", "x-display-name": "음식 이미지", "description": "음식 이미지 URL" }
              },
              "required": ["itemId", "name"]
            }
          },
          "alcoholIds": {
            "type": "array",
            "items": { "type": "integer", "format": "int64" },
            "minItems": 1,
            "x-display-name": "포함 위스키",
            "description": "큐레이션에 포함된 위스키 ID 목록",
            "x-widget": "alcohol-search",
            "x-widget-mode": "multi"
          },
          "links": {
            "type": "array",
            "x-display-name": "위스키 ↔ 음식 연결",
            "description": "위스키 ↔ 음식 연결. (alcoholId, itemId) 쌍이 한 줄.",
            "items": {
              "type": "object",
              "properties": {
                "alcoholId": { "type": "integer", "format": "int64", "x-display-name": "위스키", "description": "연결되는 위스키 ID" },
                "itemId":    { "type": "string",  "x-display-name": "음식", "description": "연결되는 음식 itemId (위 items 배열의 itemId 와 일치)" },
                "note":      { "type": "string",  "x-display-name": "연결 코멘트", "description": "이 연결에 대한 큐레이터 코멘트" }
              },
              "required": ["alcoholId", "itemId"]
            }
          }
        },
        "required": ["primaryAxis", "items", "alcoholIds", "links"]
      },
      "PairingMatrixCurationResponse": {
        "type": "object",
        "description": "페어링 매트릭스 큐레이션 조회 응답. alcoholIds 배열은 알코올 마스터에서 조회한 객체 배열(alcohols) 로 치환되고, 매트릭스 통계(stats)는 서버가 조회 시점에 계산해 채운다.",
        "properties": {
          "primaryAxis": { "type": "string", "description": "기준 축 (등록값 그대로)" },
          "items": {
            "type": "array",
            "description": "음식(아이템) 목록 (등록값 그대로)",
            "items": {
              "type": "object",
              "properties": {
                "itemId":   { "type": "string" },
                "name":     { "type": "string" },
                "imageUrl": { "type": "string" }
              },
              "required": ["itemId", "name"]
            }
          },
          "alcohols": {
            "type": "array",
            "description": "alcoholIds 각 항목을 알코올 마스터에서 조회 시점에 채워 만든 객체 배열",
            "items": {
              "type": "object",
              "properties": {
                "alcoholId":   { "type": "integer", "format": "int64", "description": "알코올 ID" },
                "korName":     { "type": "string",  "description": "알코올 한글 이름. 알코올 마스터에서 조회 시점에 채워지는 값." },
                "engName":     { "type": "string",  "description": "알코올 영문 이름. 알코올 마스터에서 조회 시점에 채워지는 값." },
                "imageUrl":    { "type": "string",  "description": "알코올 대표 이미지 URL. 알코올 마스터에서 조회 시점에 채워지는 값." },
                "korCategory": { "type": "string",  "description": "알코올 카테고리 (싱글몰트/블렌디드 등). 알코올 마스터에서 조회 시점에 채워지는 값." },
                "abv":         { "type": "string",  "description": "도수(%). 알코올 마스터에서 조회 시점에 채워지는 값." }
              },
              "required": ["alcoholId", "korName"]
            }
          },
          "links": {
            "type": "array",
            "description": "위스키 ↔ 음식 연결 (등록값 그대로)",
            "items": {
              "type": "object",
              "properties": {
                "alcoholId": { "type": "integer", "format": "int64" },
                "itemId":    { "type": "string" },
                "note":      { "type": "string" }
              },
              "required": ["alcoholId", "itemId"]
            }
          },
          "stats": {
            "type": "object",
            "description": "서버가 조회 시점에 계산하는 매트릭스 집계 (저장값 아님)",
            "properties": {
              "alcoholCount":  { "type": "integer", "description": "큐레이션에 포함된 위스키 개수" },
              "itemCount":     { "type": "integer", "description": "큐레이션에 포함된 음식 개수" },
              "linkCount":     { "type": "integer", "description": "전체 연결(링크) 개수" },
              "unlinkedCount": { "type": "integer", "description": "어떤 음식과도 연결되지 않은 위스키(또는 그 반대) 개수" }
            }
          }
        }
      }
    }
  }
}
