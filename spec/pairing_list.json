{
  "openapi": "3.0.3",
  "info": {
    "title": "페어링 (음식 카드형)",
    "description": "한 묶음 = 음식 1 + 위스키 N + 페어링 노트. 카드 N개 리스트.",
    "version": "1.0.0"
  },
  "x-curation": {
    "code": "PAIRING_LIST",
    "hydratorKey": "alcohol",
    "container": "array"
  },
  "paths": {},
  "components": {
    "schemas": {
      "PairingListItemRequest": {
        "type": "object",
        "description": "페어링 카드(음식 1 + 위스키 N) 한 묶음 등록 요청",
        "x-form-style": "pairing-list",
        "properties": {
          "itemName": {
            "type": "string",
            "description": "페어링 음식 이름",
            "example": "다크 초콜릿 70%",
            "x-field-style": "plain-text",
            "x-display-name": "페어링 음식 이름"
          },
          "itemImageUrl": {
            "type": "string",
            "description": "페어링 음식 이미지 URL (추후 업로드 위젯 대체 예정)",
            "example": "https://img/dark-choco.png",
            "x-field-style": "image-upload",
            "x-display-name": "페어링 음식 이미지 (1장)"
          },
          "alcoholIds": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64",
              "description": "위스키 ID",
              "example": 1,
              "x-field-style": "plain-number"
            },
            "minItems": 1,
            "description": "여러 개 선택 가능 · 위스키 DB에서 바인딩됩니다.",
            "example": [1, 5],
            "x-field-style": "alcohol-search-multi",
            "x-display-name": "페어링되는 위스키"
          },
          "pairingNote": {
            "type": "string",
            "description": "페어링 설명 (큐레이터 코멘트)",
            "example": "피트와 카카오의 만남",
            "x-field-style": "long-text",
            "x-display-name": "페어링 설명"
          }
        },
        "required": ["itemName", "alcoholIds"]
      },
      "PairingListItemResponse": {
        "type": "object",
        "description": "페어링 카드 조회 응답.",
        "x-form-style": "pairing-list",
        "x-graphql": {
          "query":   "alcohols",
          "argFrom": "$.alcoholIds",
          "argName": "ids",
          "argType": "[ID!]!",
          "writeTo": "alcohols"
        },
        "properties": {
          "itemName": {
            "type": "string",
            "description": "페어링 음식 이름",
            "example": "다크 초콜릿 70%",
            "x-field-style": "plain-text",
            "x-display-name": "페어링 음식 이름"
          },
          "itemImageUrl": {
            "type": "string",
            "description": "페어링 음식 이미지 URL",
            "example": "https://img/dark-choco.png",
            "x-field-style": "image-url",
            "x-display-name": "음식 이미지"
          },
          "alcohols": {
            "type": "array",
            "description": "alcoholIds → alcohol 객체 배열로 hydrate 된 결과",
            "example": [{ "alcoholId": 1, "korName": "라이터스 티얼즈" }],
            "x-field-style": "alcohol-card-list",
            "x-display-name": "페어링 위스키",
            "items": {
              "type": "object",
              "description": "알코올 단건 (마스터 hydrate)",
              "example": { "alcoholId": 1, "korName": "라이터스 티얼즈" },
              "x-field-style": "alcohol-card",
              "properties": {
                "alcoholId": {
                  "type": "integer",
                  "format": "int64",
                  "description": "알코올 ID",
                  "example": 1,
                  "x-field-style": "plain-number",
                  "x-graphql": true
                },
                "korName": {
                  "type": "string",
                  "description": "한글명",
                  "example": "라이터스 티얼즈",
                  "x-field-style": "plain-text",
                  "x-graphql": true
                },
                "engName": {
                  "type": "string",
                  "description": "영문명",
                  "example": "Writers' Tears",
                  "x-field-style": "plain-text",
                  "x-graphql": true
                },
                "imageUrl": {
                  "type": "string",
                  "description": "이미지 URL",
                  "example": "https://img/...",
                  "x-field-style": "image-url",
                  "x-graphql": true
                }
              },
              "required": ["alcoholId", "korName"]
            }
          },
          "pairingNote": {
            "type": "string",
            "description": "페어링 설명",
            "example": "피트와 카카오의 만남",
            "x-field-style": "long-text",
            "x-display-name": "페어링 설명"
          }
        },
        "required": ["itemName", "alcohols"]
      }
    }
  }
}
