{
  "openapi": "3.0.3",
  "info": {
    "title": "페어링 (음식 카드형)",
    "description": "한 묶음 = 음식 1 + 위스키 N + 페어링 노트. 카드 N개 리스트.",
    "version": "1.0.0"
  },
  "x-curation": {
