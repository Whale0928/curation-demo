                  "x-display-name": "이미지",
                  "x-graphql": true
                },
                "comment": {
                  "type": "string",
                  "description": "시음 위스키 설명",
                  "example": "첫 잔으로 가볍게 시작하는 위스키",
                  "x-field-style": "long-text",
                  "x-display-name": "위스키 기대평"
                }
              },
              "required": ["alcoholId", "korName"]
