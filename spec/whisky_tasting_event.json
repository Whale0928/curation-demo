        "x-form-style": "tasting-form",
        "properties": {
          "eventDate": {
            "type": "string",
            "format": "date",
            "description": "시음회 날짜",
            "example": "2025-06-15",
            "x-field-style": "none",
            "x-display-name": "시음회 날짜"
          },
          "eventTime": {
            "type": "string",
            "description": "시음회 시간",
            "example": "19:30",
            "x-field-style": "none",
            "x-display-name": "시음회 시간"
          },
          "barAddress": {
            "type": "string",
            "description": "장소 및 바 주소",
            "example": "서울 강남구 테헤란로 123",
            "x-field-style": "plain-text",
            "x-display-name": "장소 및 바(bar) 주소"
          },
          "detailAddress": {
            "type": "string",
