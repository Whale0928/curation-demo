              "example": { "alcoholId": 1, "korName": "글렌드로낙 오리지널 12년", "comment": "첫 잔으로 가볍게 시작하는 위스키" },
              "x-field-style": "alcohol-card",
              "x-display-name": "시음 위스키",
              "properties": {
                "alcoholId": {
                  "type": "integer",
                  "format": "int64",
                  "description": "알코올 ID",
